<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">
  <!-- Homepage -->
  <url>
    <loc>http://localhost:3000/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- Static Pages -->
  <url>
    <loc>http://localhost:3000/categories</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>http://localhost:3000/search</loc>
    <changefreq>daily</changefreq>
    <priority>0.6</priority>
  </url>

  <url>
    <loc>http://localhost:3000/support</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>

  <url>
    <loc>http://localhost:3000/cart</loc>
    <changefreq>monthly</changefreq>
    <priority>0.4</priority>
  </url>

  <url>
    <loc>http://localhost:3000/orders</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>

  <url>
    <loc>http://localhost:3000/wishlist</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>

  <!-- 
    NOTE: Add product and category URLs below manually when you have data.
    Format:
    <url>
      <loc>http://localhost:3000/products/slug</loc>
      <changefreq>weekly</changefreq>
      <priority>0.7</priority>
    </url>
    
    For production, replace "http://localhost:3000" with your actual domain.
  -->
</urlset>
